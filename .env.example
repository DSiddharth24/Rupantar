# ─────────────────────────────────────────────────────────────────────────────
# Rupantar — environment variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Meta WhatsApp Cloud API ────────────────────────────────────────────────
META_ACCESS_TOKEN=          # system user long-lived token
META_PHONE_NUMBER_ID=       # from the WhatsApp API Setup page
META_WABA_ID=               # WhatsApp Business Account ID
META_VERIFY_TOKEN=          # your own arbitrary string, used for webhook GET verification
META_APP_SECRET=            # optional but recommended, for validating webhook payload signatures

# ── Legacy (Twilio) ────────────────────────────────────────────────────────
# Find these in your Twilio Console → Account Info
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here

# The WhatsApp-enabled number in E.164 format with the whatsapp: prefix.
# For sandbox dev: whatsapp:+14155238886
# For production WABA: whatsapp:+your_business_number
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001

# The publicly reachable base URL of this server.
# Used to build /file/:token links that Twilio fetches for outbound media.
# Local dev: use your ngrok URL (e.g. https://abc123.ngrok.io)
# Production: your actual domain (e.g. https://rupantar.yourdomain.com)
PUBLIC_BASE_URL=https://your-ngrok-or-domain-here.example.com

# ── Gotenberg ──────────────────────────────────────────────────────────────
# When running with docker-compose: http://gotenberg:3000
# When running Gotenberg separately or locally: http://localhost:3000
GOTENBERG_URL=http://localhost:3000

# ── pdf2docx-plus (PDF → DOCX sidecar) ────────────────────────────────────
# When running with docker-compose: http://pdf2docx:8000
# When running separately or locally: http://localhost:8001
# (docker-compose maps container port 8000 → host port 8001)
PDF2DOCX_URL=http://localhost:8001

# ── Redis (optional) ───────────────────────────────────────────────────────
# Only needed if you switch services/session.js to use Redis instead of the
# default in-process Map. If set, ensure the Redis instance has persistence
# fully disabled (no RDB, no AOF) to comply with the zero-storage design.
# Leave blank to use the in-process Map (default, fine for single-instance).
REDIS_URL=
